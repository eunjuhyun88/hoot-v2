{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "lib": ["ES2022", "DOM"],
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "paths": {
      "@mesh/contracts": ["./packages/contracts/src/index.ts"],
      "@mesh/domain": ["./packages/domain/src/index.ts"],
      "@mesh/autoresearch-adapter": ["./packages/autoresearch-adapter/src/index.ts"]
    }
  },
  "include": ["src", "src-svelte", "apps", "packages", "eval"]
}
