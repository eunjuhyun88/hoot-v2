{
  "version": 1,
  "project": {
    "name": "HOOT Protocol Visualizer",
    "slug": "hoot-protocol-visualizer",
    "summary": "Interactive protocol explorer and autonomous research mesh dashboard with continuous autoresearch runtime",
    "stack": "Svelte 5 / TypeScript / Vite / Node / Autoresearch",
    "phase": "architecture split and continuous autoresearch rollout",
    "deadline": "TBD"
  },
  "git": {
    "mainBranch": "main"
  },
  "discovery": {
    "routesDir": "src-svelte/lib/pages",
    "storesDir": "src-svelte/lib/stores",
    "apiDir": "scripts"
  },
  "claude": {
    "enabled": true,
    "settingsPath": ".claude/settings.json",
    "riskyPathHints": [
      "src-svelte/lib/stores",
      "scripts",
      "runtime",
      "memory"
    ]
  },
  "surfaces": [
  {
    "id": "web",
    "label": "Web surface",
    "summary": "Svelte UI shell, pages, stores, visual components, and browser interaction.",
    "spec": "docs/product-specs/web.md",
    "routes": [
      "/#/",
      "/#/research",
      "/#/network",
      "/#/models",
      "/#/protocol"
    ],
    "stores": [
      "router",
      "jobStore",
      "wallet"
    ],
    "apis": [
      "/events"
    ]
  },
  {
    "id": "runtime-api",
    "label": "Runtime-Api surface",
    "summary": "Autoresearch controller, supervisor, telemetry stream, runtime persistence, and future API service.",
    "spec": "docs/product-specs/runtime-api.md",
    "routes": [
      "/events",
      "/healthz",
      "/manifest",
      "/state"
    ],
    "stores": [],
    "apis": [
      "/events",
      "/healthz",
      "/manifest",
      "/state"
    ]
  },
  {
    "id": "protocol",
    "label": "Protocol surface",
    "summary": "HOOT protocol terminology, economics, and protocol-facing user flows.",
    "spec": "docs/product-specs/protocol.md",
    "routes": [
      "/#/protocol"
    ],
    "stores": [],
    "apis": []
  }
],
  "harness": {
    "pages": [
      "/#/",
      "/#/research",
      "/#/network",
      "/#/protocol"
    ],
    "apis": [],
    "browserPages": [
      "/#/",
      "/#/research",
      "/#/network",
      "/#/protocol"
    ]
  },
	  "coordination": {
	    "requireClaimOnFeatureBranches": true,
	    "requirePathsOnFeatureBranches": true,
	    "featureBranchPrefixes": [
	      "codex/",
	      "claude/",
	      "feat/"
	    ],
	    "defaultLeaseMinutes": 240,
	    "lockStaleMinutes": 15,
	    "failOnExpiredClaims": true,
	    "failOnPathOverlap": true,
	    "failOnUnscopedSurfaceOverlap": true,
	    "sharedPathPrefixes": [
      "docs/AGENT_WATCH_LOG.md",
      "docs/generated/",
	      ".agent-context/"
	    ]
	  },
	  "autopilot": {
	    "enabled": true,
	    "agentId": "autopilot",
	    "autoSave": true,
	    "autoCheckpoint": true,
	    "autoClaim": true,
	    "autoCompactOnStop": true,
	    "autoCompactOnPreCompact": true,
	    "autoCommit": true,
	    "autoCommitStages": [
	      "stop",
	      "pre-push"
	    ],
	    "autoCommitMessagePrefix": "chore(context): autosave",
	    "minimumClaimPathDepth": 2,
	    "defaultSurface": "web",
	    "defaultObjectivePrefix": "Resume branch work on",
	    "defaultDocs": [
	      "README.md",
	      "AGENTS.md",
	      "docs/README.md",
	      "ARCHITECTURE.md",
	      "docs/CONTEXT_ENGINEERING.md"
	    ],
	    "minIntervalSec": 300
	  },
	  "registry": {
	    "enabled": true,
	    "manifestPath": "docs/generated/context-registry.json",
	    "publicBaseUrl": "",
	    "publishTags": [
	      "hoot-protocol-visualizer",
	      "context-kit"
	    ],
	    "searchKinds": [
	      "surface",
	      "doc",
	      "command",
	      "retrieval",
	      "agent",
	      "tool"
	    ]
	  },
	  "agents": {
	    "enabled": true,
	    "dir": "agents",
	    "catalogPath": "docs/generated/agent-catalog.json",
	    "defaultSurface": "web"
	  },
	  "tools": {
	    "enabled": true,
	    "dir": "tools",
	    "catalogPath": "docs/generated/tool-catalog.json",
	    "defaultSurface": "web"
	  },
	  "telemetry": {
	    "enabled": true,
	    "runsDir": ".agent-context/telemetry/runs",
	    "eventsDir": ".agent-context/telemetry/events",
	    "activeDir": ".agent-context/telemetry/active",
	    "lockPath": ".agent-context/telemetry/telemetry.lock",
	    "lockStaleMinutes": 5,
	    "reportPath": "docs/generated/agent-usage-report.json",
	    "defaults": {
	      "taskComplexity": "moderate",
	      "skillLevel": "experienced",
	      "purpose": "product-development",
	      "autonomy": "assisted"
	    }
	  },
	  "retrieval": {
	    "enabled": true,
	    "includePaths": [
	      "README.md",
	      "AGENTS.md",
	      "CLAUDE.md",
	      "ARCHITECTURE.md",
	      "memory/",
	      "docs/SYSTEM_INTENT.md",
	      "docs/CONTEXT_ENGINEERING.md",
	      "docs/CONTEXT_EVALUATION.md",
	      "docs/CONTEXT_PLATFORM.md",
	      "docs/CONTEXTUAL_RETRIEVAL.md",
	      "docs/AGENT_FACTORY.md",
	      "docs/TOOL_DESIGN.md",
	      "docs/AGENT_OBSERVABILITY.md",
	      "docs/MULTI_AGENT_COORDINATION.md",
	      "docs/SANDBOX_POLICY.md",
	      "docs/DESIGN.md",
	      "docs/ENGINEERING.md",
	      "docs/PLANS.md",
	      "docs/PRODUCT_SENSE.md",
	      "docs/QUALITY_SCORE.md",
	      "docs/RELIABILITY.md",
	      "docs/SECURITY.md",
	      "docs/HARNESS.md",
	      "agents/",
	      "tools/",
	      "docs/design-docs/",
	      "docs/product-specs/"
	    ],
	    "excludePaths": [
	      "docs/archive/",
	      "docs/generated/",
	      ".agent-context/"
	    ],
	    "chunkWords": 120,
	    "overlapWords": 30,
	    "defaultTopK": 5,
	    "contextualWeight": 0.65,
	    "rawWeight": 0.35,
	    "pathBoost": 0.8,
	    "headingBoost": 0.5,
	    "surfaceBoost": 0.75,
	    "indexPath": "docs/generated/contextual-retrieval-index.json"
	  },
	  "sandbox": {
	    "enabled": true,
	    "allowReadPaths": [
	      "README.md",
	      "AGENTS.md",
	      "CLAUDE.md",
	      "ARCHITECTURE.md",
	      "context-kit.json",
	      "docs/",
	      "agents/",
	      "tools/",
	      "src-svelte/",
	      "scripts/",
	      "memory/",
	      "eval/",
	      "package.json"
	    ],
	    "allowWritePaths": [
	      ".agent-context/",
	      "docs/generated/",
	      "scripts/dev/",
	      "src-svelte/",
	      "scripts/",
	      "memory/",
	      ".claude/",
	      ".githooks/",
	      "package.json"
	    ],
	    "allowNetworkHosts": [
	      "127.0.0.1",
	      "localhost"
	    ],
	    "denyCommandPrefixes": [
	      "rm -rf",
	      "git reset --hard",
	      "git checkout --",
	      "curl | sh"
	    ],
	    "requireApprovalCommandPrefixes": [
	      "git push",
	      "npm publish",
	      "docker push"
	    ],
	    "credentialEnvAllowlist": []
	  },
	  "evaluation": {
	    "targets": {
	      "smallMapReductionVsCanonicalPct": 40,
      "smallMapReductionVsAllDocsPct": 55,
      "surfaceReductionVsAllDocsPct": 50,
      "smallMapMaxApproxTokens": 3800,
      "smallMapMaxFiles": 6,
      "canonicalMaxApproxTokens": 12000,
      "noiseRateMaxPct": 10
    },
	    "benchmark": {
	      "runs": 3,
	      "warmupRuns": 1,
	      "mode": "smoke",
	      "maxDurationCvPct": 15
	    },
	    "ab": {
	      "minComparisons": 1,
	      "targetDocsBeforeFirstEdit": 6,
	      "targetResumeLatencyMinutes": 3
	    }
	  },
	  "commands": {
    "check": "npm run eval:globe",
    "build": "npm run build",
    "gate": "npm run build"
  }
}
